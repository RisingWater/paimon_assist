# 派萌助手 — 配置模板
# 复制此文件为 .env 并填入你自己的值

# DeepSeek API（必填）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# TTS 后端: "vits"=本地VITS模型, "web"=HTTP网络TTS
TTS_BACKEND=vits
# Web TTS 服务地址（仅 TTS_BACKEND=web 时使用）
TTS_URL=http://192.168.1.180:6018/api/tts/speak

# 唤醒词模型路径
MODEL_PATH=models/paimeng.onnx
# 唤醒灵敏度（0~1，越低越灵敏）
THRESHOLD=0.25
# 唤醒后冷却时间（秒）
DEBOUNCE=1.0

# VAD 静音判定（毫秒）
VAD_SILENCE_MS=800
# 单次录音最大时长（秒）
MAX_RECORD_SECONDS=10

# 设为 1 禁用模型在线更新（离线使用）
DISABLE_UPDATE=0

# 声纹验证（首次唤醒自动注册，无需手动采集）
# 余弦相似度阈值（0~1，越高越严格，建议 0.7~0.8）
VOICEPRINT_THRESHOLD=0.75
# 声纹数据库路径（SQLite，支持多人存储）
# VOICEPRINT_DB=models/voiceprints.db
# 声纹模型（中文优化，短语音2-3秒即可识别）
# VOICEPRINT_MODEL=iic/speech_eres2netv2_sv_zh-cn_16k-common

# Web 管理界面端口
# WEB_PORT=8160
